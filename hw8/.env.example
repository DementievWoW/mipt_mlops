# Скопируйте этот файл в .env и впишите свои значения.
# .env находится в .gitignore и не должен попадать в репозиторий.

# Токен Telegram-бота, выдаётся @BotFather (/newbot).
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQrStUVwxyZ

# ID чата, куда бот будет писать.
# Личный chat_id можно получить у @userinfobot или из
#   https://api.telegram.org/bot<TOKEN>/getUpdates  после отправки сообщения боту.
TELEGRAM_CHAT_ID=123456789
